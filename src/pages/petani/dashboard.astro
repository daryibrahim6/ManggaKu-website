---
import MarketingLayout from '../../components/layout/MarketingLayout.astro'
---

<MarketingLayout title="Dashboard Petani (Demo)">
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-8">
    <!-- Demo Banner -->
    <div class="mb-6 p-4 bg-secondary-50 border border-secondary-200 rounded-xl text-center">
      <p class="text-sm text-secondary-700">
        <span class="font-semibold">Demo Mode:</span> Ini adalah tampilan dashboard petani. Fitur lengkap memerlukan akun dan login.
      </p>
    </div>

    <!-- Header Card Saldo -->
    <div class="mb-6 p-6 bg-gradient-to-r from-primary-600 to-primary-700 rounded-2xl text-white">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm opacity-80">Selamat datang, <span id="petani-name">Pak Budi</span></p>
          <p class="text-xs opacity-60 mt-1" id="petani-location">Indramayu, Jawa Barat</p>
        </div>
        <div class="text-right">
          <p class="text-sm opacity-80">Saldo Siap Tarik</p>
          <p class="font-mono text-3xl md:text-4xl font-bold mt-1" id="stat-balance">Rp 2.150.000</p>
        </div>
      </div>
      <button type="button" class="mt-4 px-6 py-2 bg-white text-primary-600 font-semibold rounded-xl hover:bg-neutral-50 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-primary-600">
        Tarik Dana
      </button>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="p-4 bg-white rounded-2xl shadow-sm border border-neutral-100">
        <div class="w-10 h-10 bg-primary-50 rounded-xl flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
        <p class="font-mono text-xl md:text-2xl font-bold text-neutral-900" id="stat-products">0</p>
        <p class="text-xs text-neutral-500 mt-1">Total Produk</p>
      </div>
      <div class="p-4 bg-white rounded-2xl shadow-sm border border-neutral-100">
        <div class="w-10 h-10 bg-primary-50 rounded-xl flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <p class="font-mono text-xl md:text-2xl font-bold text-neutral-900" id="stat-orders">0</p>
        <p class="text-xs text-neutral-500 mt-1">Total Pesanan</p>
        <p class="text-xs text-green-600 mt-1" id="stat-orders-change">0 pesanan baru</p>
      </div>
      <div class="p-4 bg-white rounded-2xl shadow-sm border border-neutral-100">
        <div class="w-10 h-10 bg-primary-50 rounded-xl flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <p class="font-mono text-xl md:text-2xl font-bold text-neutral-900" id="stat-revenue">Rp 0</p>
        <p class="text-xs text-neutral-500 mt-1">Total Pendapatan</p>
      </div>
      <div class="p-4 bg-white rounded-2xl shadow-sm border border-neutral-100">
        <div class="w-10 h-10 bg-primary-50 rounded-xl flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
        </div>
        <p class="font-mono text-xl md:text-2xl font-bold text-neutral-900" id="stat-rating">0</p>
        <p class="text-xs text-neutral-500 mt-1">Rating Toko</p>
      </div>
    </div>

    <!-- Sales Chart Mockup -->
    <div class="mb-6 p-6 bg-white rounded-2xl shadow-sm border border-neutral-100">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold text-neutral-900">Grafik Penjualan</h2>
        <div class="flex gap-2">
          <button type="button" class="px-3 py-1 text-xs font-medium bg-primary-100 text-primary-700 rounded-lg">7 Hari</button>
          <button type="button" class="px-3 py-1 text-xs font-medium text-neutral-500 hover:bg-neutral-50 rounded-lg">30 Hari</button>
          <button type="button" class="px-3 py-1 text-xs font-medium text-neutral-500 hover:bg-neutral-50 rounded-lg">3 Bulan</button>
        </div>
      </div>
      <div class="h-64 bg-neutral-50 rounded-xl flex items-center justify-center border border-neutral-100">
        <div class="text-center">
          <svg class="w-12 h-12 text-neutral-300 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          <p class="text-sm text-neutral-500">Grafik penjualan akan ditampilkan di sini</p>
          <p class="text-xs text-neutral-400 mt-1">Menggunakan Recharts AreaChart</p>
        </div>
      </div>
    </div>

    <!-- Products Section -->
    <div class="mb-6 bg-white rounded-2xl shadow-sm border border-neutral-100">
      <div class="flex items-center justify-between p-6 border-b border-neutral-100">
        <h2 class="font-semibold text-neutral-900">Produk Saya</h2>
        <a href="/petani/produk" class="text-sm text-primary-600 hover:text-primary-700 font-medium focus:outline-none focus:ring-2 focus:ring-primary-500 rounded-lg px-2 py-1">
          Kelola Semua →
        </a>
      </div>
      <div id="products-list" class="divide-y divide-neutral-100">
        <div class="p-6 text-center text-neutral-400 text-sm">Memuat produk...</div>
      </div>
    </div>

    <!-- Low Stock Alert -->
    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <h3 class="font-semibold text-red-700">Stok Rendah</h3>
      </div>
      <div id="low-stock-list" class="space-y-2">
        <p class="text-sm text-red-600">Memuat data stok...</p>
      </div>
    </div>

    <!-- Recent Orders -->
    <div class="bg-white rounded-2xl shadow-sm border border-neutral-100">
      <div class="flex items-center justify-between p-6 border-b border-neutral-100">
        <h2 class="font-semibold text-neutral-900">Pesanan Terbaru</h2>
        <a href="/petani/pesanan" class="text-sm text-primary-600 hover:text-primary-700 font-medium focus:outline-none focus:ring-2 focus:ring-primary-500 rounded-lg px-2 py-1">
          Lihat Semua →
        </a>
      </div>
      <div id="recent-orders" class="divide-y divide-neutral-100">
        <div class="p-6 text-center text-neutral-400 text-sm">Memuat pesanan...</div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-4">
      <a href="/petani/produk/tambah" class="p-4 bg-white rounded-xl shadow-sm border border-neutral-100 text-center hover:bg-primary-50 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500">
        <div class="w-10 h-10 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-2">
          <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
        </div>
        <p class="text-sm font-medium text-neutral-900">Tambah Produk</p>
      </a>
      <a href="/petani/produk" class="p-4 bg-white rounded-xl shadow-sm border border-neutral-100 text-center hover:bg-primary-50 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500">
        <div class="w-10 h-10 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-2">
          <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
        </div>
        <p class="text-sm font-medium text-neutral-900">Kelola Produk</p>
      </a>
      <a href="/petani/pesanan" class="p-4 bg-white rounded-xl shadow-sm border border-neutral-100 text-center hover:bg-primary-50 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500">
        <div class="w-10 h-10 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-2">
          <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <p class="text-sm font-medium text-neutral-900">Lihat Pesanan</p>
      </a>
      <a href="/petani/laporan" class="p-4 bg-white rounded-xl shadow-sm border border-neutral-100 text-center hover:bg-primary-50 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500">
        <div class="w-10 h-10 bg-primary-100 rounded-xl flex items-center justify-center mx-auto mb-2">
          <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <p class="text-sm font-medium text-neutral-900">Lihat Laporan</p>
      </a>
    </div>
  </div>
</MarketingLayout>

<script type="application/json" id="dashboard-data">
{
  "petani": {
    "name": "Pak Budi",
    "location": "Indramayu, Jawa Barat",
    "rating": 4.8,
    "totalSales": 156,
    "joinedDate": "2024-01-15"
  },
  "stats": {
    "totalProducts": 6,
    "totalOrders": 45,
    "totalRevenue": 2340000,
    "avgRating": 4.8
  },
  "products": [
    { "id": "prod-001", "name": "Mangga Gedong Gincu", "stock": 50, "price": 35000, "sold": 89, "rating": 4.9, "unit": "kg", "image": "https://images.unsplash.com/photo-1553279768-865429fa0078?w=400&h=400&fit=crop" },
    { "id": "prod-002", "name": "Mangga Harum Manis", "stock": 35, "price": 42000, "sold": 67, "rating": 4.7, "unit": "kg", "image": "https://images.unsplash.com/photo-1550258987-190a2d41a8ba?w=400&h=400&fit=crop" },
    { "id": "prod-003", "name": "Mangga Cengkir", "stock": 120, "price": 28000, "sold": 145, "rating": 4.8, "unit": "kg", "image": "https://images.unsplash.com/photo-1605001011156-cbf0b0f67a51?w=400&h=400&fit=crop" },
    { "id": "prod-004", "name": "Mangga Manalagi", "stock": 8, "price": 30000, "sold": 32, "rating": 4.5, "unit": "kg", "image": "https://images.unsplash.com/photo-1571771894821-ce9b6c11b08e?w=400&h=400&fit=crop" },
    { "id": "prod-005", "name": "Mangga Indramayu", "stock": 95, "price": 25000, "sold": 78, "rating": 4.6, "unit": "kg", "image": "https://images.unsplash.com/photo-1553279768-865429fa0078?w=400&h=400&fit=crop" },
    { "id": "prod-006", "name": "Mangga Kweni", "stock": 3, "price": 38000, "sold": 21, "rating": 4.3, "unit": "kg", "image": "https://images.unsplash.com/photo-1550258987-190a2d41a8ba?w=400&h=400&fit=crop" }
  ],
  "recentOrders": [
    { "id": "SM-2026-ABC12", "customer": "Siti Aminah", "product": "Mangga Gedong Gincu", "quantity": 5, "total": 175000, "status": "baru", "date": "2026-06-13" },
    { "id": "SM-2026-DEF34", "customer": "Andi Pratama", "product": "Mangga Harum Manis", "quantity": 3, "total": 126000, "status": "diproses", "date": "2026-06-12" },
    { "id": "SM-2026-GHI56", "customer": "Dewi Lestari", "product": "Mangga Cengkir", "quantity": 5, "total": 140000, "status": "dikirim", "date": "2026-06-12" },
    { "id": "SM-2026-JKL78", "customer": "Rina Wati", "product": "Mangga Manalagi", "quantity": 1, "total": 30000, "status": "selesai", "date": "2026-06-11" },
    { "id": "SM-2026-MNO90", "customer": "Budi Santoso", "product": "Mangga Kweni", "quantity": 2, "total": 76000, "status": "baru", "date": "2026-06-11" }
  ]
}
</script>

<script>
(function() {
  const dataEl = document.getElementById('dashboard-data');
  if (!dataEl) return;
  const data = JSON.parse(dataEl.textContent);

  const fmt = (n) => 'Rp ' + n.toLocaleString('id-ID');

  const nameEl = document.getElementById('petani-name');
  const locEl = document.getElementById('petani-location');
  if (nameEl) nameEl.textContent = data.petani.name;
  if (locEl) locEl.textContent = data.petani.location;

  const statProducts = document.getElementById('stat-products');
  const statOrders = document.getElementById('stat-orders');
  const statRevenue = document.getElementById('stat-revenue');
  const statRating = document.getElementById('stat-rating');
  if (statProducts) statProducts.textContent = data.stats.totalProducts;
  if (statOrders) statOrders.textContent = data.stats.totalOrders;
  if (statRevenue) statRevenue.textContent = fmt(data.stats.totalRevenue);
  if (statRating) statRating.textContent = data.stats.avgRating.toFixed(1);

  const ordersChange = document.getElementById('stat-orders-change');
  if (ordersChange) {
    const newOrders = data.recentOrders.filter(o => o.status === 'baru').length;
    ordersChange.textContent = newOrders + ' pesanan baru';
  }

  const balance = data.products.reduce((sum, p) => sum + (p.price * p.sold), 0);
  const balanceEl = document.getElementById('stat-balance');
  if (balanceEl) balanceEl.textContent = fmt(balance);

  const statusBadge = {
    baru: { label: 'Baru', cls: 'bg-primary-100 text-primary-700' },
    diproses: { label: 'Diproses', cls: 'bg-secondary-100 text-secondary-700' },
    dikirim: { label: 'Dikirim', cls: 'bg-blue-100 text-blue-700' },
    selesai: { label: 'Selesai', cls: 'bg-green-100 text-green-700' }
  };

  const productsList = document.getElementById('products-list');
  if (productsList) {
    if (data.products.length === 0) {
      productsList.innerHTML = '<div class="p-6 text-center text-neutral-400 text-sm">Belum ada produk</div>';
    } else {
      productsList.innerHTML = data.products.map(p => `
        <div class="p-4 md:p-6 hover:bg-neutral-50 transition-colors">
          <div class="flex items-center gap-4">
            <img src="${p.image}" alt="${p.name}" class="w-14 h-14 rounded-xl object-cover border border-neutral-100" />
            <div class="flex-1 min-w-0">
              <p class="font-medium text-neutral-900 truncate">${p.name}</p>
              <p class="text-sm text-neutral-500">${fmt(p.price)} / ${p.unit}</p>
            </div>
            <div class="text-right hidden sm:block">
              <p class="text-sm font-medium ${p.stock < 10 ? 'text-red-600' : 'text-neutral-900'}">Stok: ${p.stock} ${p.unit}</p>
              <p class="text-xs text-neutral-500">Terjual: ${p.sold}</p>
            </div>
            <div class="text-right hidden md:block">
              <div class="flex items-center gap-1 text-sm text-amber-500">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <span>${p.rating}</span>
              </div>
            </div>
          </div>
        </div>
      `).join('');
    }
  }

  const lowStockList = document.getElementById('low-stock-list');
  if (lowStockList) {
    const lowStock = data.products.filter(p => p.stock < 10);
    if (lowStock.length === 0) {
      lowStockList.innerHTML = '<p class="text-sm text-green-600">Semua stok dalam kondisi aman.</p>';
    } else {
      lowStockList.innerHTML = lowStock.map(p => `
        <div class="flex items-center justify-between text-sm">
          <span class="text-red-700">${p.name} - ${p.stock} ${p.unit} tersisa</span>
          <button type="button" class="text-red-600 font-medium hover:underline focus:outline-none focus:ring-2 focus:ring-red-500 rounded">
            Update Stok
          </button>
        </div>
      `).join('');
    }
  }

  const recentOrders = document.getElementById('recent-orders');
  if (recentOrders) {
    if (data.recentOrders.length === 0) {
      recentOrders.innerHTML = '<div class="p-6 text-center text-neutral-400 text-sm">Belum ada pesanan</div>';
    } else {
      recentOrders.innerHTML = data.recentOrders.map(o => {
        const badge = statusBadge[o.status] || { label: o.status, cls: 'bg-neutral-100 text-neutral-700' };
        return `
          <div class="p-4 md:p-6 hover:bg-neutral-50 transition-colors">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2">
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <p class="font-mono text-sm font-medium text-neutral-900">${o.id}</p>
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full ${badge.cls}">${badge.label}</span>
                </div>
                <p class="text-sm text-neutral-500 mt-1">${o.customer} &bull; ${o.product} (${o.quantity} ${o.product.includes('Bulk') ? 'box' : 'kg'})</p>
              </div>
              <div class="flex items-center gap-4">
                <span class="font-mono text-sm font-medium text-secondary-600">${fmt(o.total)}</span>
                <button type="button" class="text-sm text-primary-600 hover:text-primary-700 font-medium focus:outline-none focus:ring-2 focus:ring-primary-500 rounded-lg px-2 py-1">
                  Detail
                </button>
              </div>
            </div>
          </div>
        `;
      }).join('');
    }
  }
})();
</script>
