---
export const prerender = false

import DashboardLayout from '../../components/layout/DashboardLayout.astro'
---

<DashboardLayout title="Manajemen Stok" role="petani">
  <div class="space-y-4">
    <h1 class="font-display text-2xl font-bold text-leaf-900">Manajemen Stok</h1>

    <div class="bg-white rounded-2xl shadow-sm border border-leaf-100/50 overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-leaf-100">
            <th class="px-4 py-3 text-left text-xs font-semibold text-leaf-700/70">Produk</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-leaf-700/70">Stok Saat Ini</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-leaf-700/70">Update Stok</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-leaf-50">
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <span>🥭</span>
                <span class="font-medium text-leaf-900">Mangga Gedong Gincu</span>
              </div>
            </td>
            <td class="px-4 py-3">
              <span class="font-mono text-red-500 font-medium">5 kg</span>
            </td>
            <td class="px-4 py-3">
              <input type="number" class="w-24 px-3 py-1.5 rounded-lg border border-leaf-200 text-sm" placeholder="Jumlah" />
            </td>
          </tr>
          <tr class="border-b border-leaf-50">
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <span>🥭</span>
                <span class="font-medium text-leaf-900">Mangga Harum Manis</span>
              </div>
            </td>
            <td class="px-4 py-3">
              <span class="font-mono text-leaf-900 font-medium">50 kg</span>
            </td>
            <td class="px-4 py-3">
              <input type="number" class="w-24 px-3 py-1.5 rounded-lg border border-leaf-200 text-sm" placeholder="Jumlah" />
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</DashboardLayout>
