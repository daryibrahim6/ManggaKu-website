---
export const prerender = false

import DashboardLayout from '../../components/layout/DashboardLayout.astro'
import { formatRupiah } from '../../lib/utils'
---

<DashboardLayout title="Dana" role="petani">
  <div class="max-w-2xl space-y-6">
    <h1 class="font-display text-2xl font-bold text-leaf-900">Penarikan Dana</h1>

    <div class="bg-leaf-600 rounded-2xl p-6 text-white">
      <p class="text-sm text-white/70">Saldo Tersedia</p>
      <p class="font-mono text-3xl font-bold mt-1">{formatRupiah(2450000)}</p>
    </div>

    <div class="bg-white rounded-2xl p-6 shadow-sm border border-leaf-100/50 space-y-4">
      <h3 class="font-semibold text-leaf-900">Form Penarikan</h3>

      <div class="space-y-2">
        <label class="text-sm font-medium text-leaf-900">Jumlah Penarikan</label>
        <input
          type="number"
          class="w-full px-4 py-2.5 rounded-xl border border-leaf-200 text-sm"
          placeholder="Masukkan jumlah"
        />
      </div>

      <div class="space-y-2">
        <label class="text-sm font-medium text-leaf-900">Rekening Tujuan</label>
        <select class="w-full px-4 py-2.5 rounded-xl border border-leaf-200 text-sm">
          <option value="">Pilih rekening</option>
          <option value="bca">BCA - 1234567890</option>
          <option value="mandiri">Mandiri - 0987654321</option>
        </select>
      </div>

      <button class="w-full py-3 bg-mango-500 hover:bg-mango-600 text-white font-semibold rounded-xl transition-colors">
        Tarik Dana
      </button>
    </div>

    <div class="bg-white rounded-2xl p-6 shadow-sm border border-leaf-100/50">
      <h3 class="font-semibold text-leaf-900 mb-4">Riwayat Penarikan</h3>
      <div class="space-y-3">
        <div class="flex items-center justify-between p-3 bg-leaf-50 rounded-xl">
          <div>
            <p class="text-sm font-medium text-leaf-900">Penarikan ke BCA</p>
            <p class="text-xs text-leaf-700/50">10 Jun 2026</p>
          </div>
          <span class="font-mono text-sm text-leaf-900">- {formatRupiah(500000)}</span>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
