---
export const prerender = false

import DashboardLayout from '../../components/layout/DashboardLayout.astro'
---

<DashboardLayout title="Toko Saya" role="petani">
  <div class="max-w-2xl">
    <h1 class="font-display text-2xl font-bold text-leaf-900 mb-6">Profil Toko</h1>

    <div class="bg-white rounded-2xl p-6 shadow-sm border border-leaf-100/50 space-y-4">
      <div class="space-y-2">
        <label class="text-sm font-medium text-leaf-900">Nama Toko</label>
        <input
          type="text"
          value="Kebun Pak Karso"
          class="w-full px-4 py-2.5 rounded-xl border border-leaf-200 text-sm"
        />
      </div>

      <div class="space-y-2">
        <label class="text-sm font-medium text-leaf-900">Deskripsi Toko</label>
        <textarea
          rows="3"
          class="w-full px-4 py-2.5 rounded-xl border border-leaf-200 text-sm resize-none"
          placeholder="Deskripsi toko..."
        >Menjual mangga segar pilihan dari kebun sendiri di Jatibarang, Indramayu.</textarea>
      </div>

      <div class="space-y-2">
        <label class="text-sm font-medium text-leaf-900">Lokasi</label>
        <input
          type="text"
          value="Jatibarang, Indramayu"
          class="w-full px-4 py-2.5 rounded-xl border border-leaf-200 text-sm"
        />
      </div>

      <button class="w-full py-3 bg-mango-500 hover:bg-mango-600 text-white font-semibold rounded-xl transition-colors">
        Simpan Perubahan
      </button>
    </div>
  </div>
</DashboardLayout>
