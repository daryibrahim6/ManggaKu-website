---
export const prerender = false

import AppLayout from '../../components/layout/AppLayout.astro'
---

<AppLayout title="Pembayaran">
  <div class="max-w-lg mx-auto px-4 md:px-8 py-12">
    <!-- Pending State -->
    <div id="state-pending" class="text-center space-y-6">
      <div class="w-20 h-20 bg-mango-100 rounded-full flex items-center justify-center mx-auto animate-pulse">
        <span class="text-3xl">💳</span>
      </div>

      <div>
        <h1 class="font-display text-2xl font-bold text-leaf-900">Menunggu Pembayaran</h1>
        <p class="mt-2 text-leaf-700/70">Selesaikan pembayaran sebelum waktu habis</p>
      </div>

      <div class="bg-white rounded-2xl p-6 border border-leaf-100 space-y-4">
        <div class="text-center">
          <span class="text-xs text-leaf-700/50">Nomor Pesanan</span>
          <p class="font-mono font-medium text-leaf-900">SM-2026-TEST1</p>
        </div>

        <div class="border-t border-leaf-100 pt-4">
          <span class="text-xs text-leaf-700/50">Total Pembayaran</span>
          <p class="font-mono text-2xl font-bold text-mango-500">Rp 87.100</p>
        </div>

        <div class="border-t border-leaf-100 pt-4">
          <span class="text-xs text-leaf-700/50">Instruksi Pembayaran</span>
          <div class="mt-2 p-4 bg-leaf-50 rounded-xl">
            <p class="text-sm font-medium text-leaf-900">Bayar via GoPay</p>
            <p class="text-sm text-leaf-700/70 mt-1">Klik tombol di bawah untuk membuka aplikasi GoPay</p>
          </div>
        </div>

        <div class="text-center">
          <span class="text-sm text-leaf-700/50">Bayar dalam</span>
          <p class="font-mono text-xl font-bold text-leaf-900" id="countdown">29:59</p>
        </div>
      </div>

      <button onclick="showState('success')" class="w-full py-3 bg-mango-500 hover:bg-mango-600 text-white font-semibold rounded-xl transition-colors">
        Saya Sudah Bayar
      </button>
    </div>

    <!-- Success State -->
    <div id="state-success" class="text-center space-y-6 hidden">
      <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto">
        <span class="text-3xl">✅</span>
      </div>

      <div>
        <h1 class="font-display text-2xl font-bold text-leaf-900">Pembayaran Berhasil!</h1>
        <p class="mt-2 text-leaf-700/70">Pesananmu sedang diproses</p>
      </div>

      <div class="bg-white rounded-2xl p-6 border border-leaf-100 space-y-3">
        <div class="flex justify-between text-sm">
          <span class="text-leaf-700/70">Nomor Pesanan</span>
          <span class="font-mono font-medium text-leaf-900">SM-2026-TEST1</span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-leaf-700/70">Total</span>
          <span class="font-mono font-medium text-mango-500">Rp 87.100</span>
        </div>
      </div>

      <div class="flex gap-3">
        <a href="/pesanan/SM-2026-TEST1" class="flex-1">
          <button class="w-full py-3 bg-mango-500 hover:bg-mango-600 text-white font-semibold rounded-xl transition-colors">
            Lacak Pesanan
          </button>
        </a>
        <a href="/marketplace" class="flex-1">
          <button class="w-full py-3 border border-leaf-200 text-leaf-700 font-semibold rounded-xl hover:bg-leaf-50 transition-colors">
            Lanjut Belanja
          </button>
        </a>
      </div>
    </div>

    <!-- Failed State -->
    <div id="state-failed" class="text-center space-y-6 hidden">
      <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mx-auto">
        <span class="text-3xl">❌</span>
      </div>

      <div>
        <h1 class="font-display text-2xl font-bold text-leaf-900">Pembayaran Gagal</h1>
        <p class="mt-2 text-leaf-700/70">Terjadi kesalahan saat memproses pembayaran</p>
      </div>

      <div class="flex gap-3">
        <button onclick="showState('pending')" class="flex-1 py-3 bg-mango-500 hover:bg-mango-600 text-white font-semibold rounded-xl transition-colors">
          Coba Lagi
        </button>
        <a href="/kontak" class="flex-1">
          <button class="w-full py-3 border border-leaf-200 text-leaf-700 font-semibold rounded-xl hover:bg-leaf-50 transition-colors">
            Hubungi Support
          </button>
        </a>
      </div>
    </div>
  </div>
</AppLayout>

<script>
  function showState(state: string) {
    document.getElementById('state-pending')?.classList.add('hidden')
    document.getElementById('state-success')?.classList.add('hidden')
    document.getElementById('state-failed')?.classList.add('hidden')
    document.getElementById(`state-${state}`)?.classList.remove('hidden')
  }

  // Countdown timer
  let minutes = 29
  let seconds = 59
  const countdown = document.getElementById('countdown')
  const timer = setInterval(() => {
    if (seconds === 0) {
      if (minutes === 0) {
        clearInterval(timer)
        return
      }
      minutes--
      seconds = 59
    } else {
      seconds--
    }
    if (countdown) {
      countdown.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`
    }
  }, 1000)
</script>
