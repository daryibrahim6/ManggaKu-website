---
import BaseLayout from '../../components/layout/BaseLayout.astro'
import { LoginForm } from '../../components/auth/LoginForm'
---

<BaseLayout title="Masuk">
  <div class="min-h-screen flex">
    <!-- Left: Form -->
    <div class="flex-1 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
      <div class="w-full max-w-md">
        <div class="text-center mb-8">
          <a href="/" class="inline-flex items-center gap-2">
            <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-primary-700 rounded-xl flex items-center justify-center shadow-lg shadow-primary-500/30">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
            </div>
            <span class="font-display font-bold text-2xl text-neutral-900">
              Mangga<span class="text-primary-600">Ku</span>
            </span>
          </a>
          <h1 class="mt-6 font-display text-3xl font-bold text-neutral-900">
            Masuk ke Akun
          </h1>
          <p class="mt-2 text-neutral-500">
            Belum punya akun?{' '}
            <a href="/auth/daftar" class="font-medium text-primary-600 hover:text-primary-700 transition-colors">
              Daftar sekarang
            </a>
          </p>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-neutral-100 p-6 md:p-8">
          <LoginForm client:load />
        </div>

        <p class="mt-6 text-center text-xs text-neutral-400">
          Dengan masuk, kamu setuju dengan Syarat & Ketentuan dan Kebijakan Privasi kami.
        </p>
      </div>
    </div>

    <!-- Right: Image (hidden on mobile) -->
    <div class="hidden lg:flex lg:flex-1 bg-gradient-to-br from-primary-50 via-primary-100 to-secondary-50 items-center justify-center p-12">
      <div class="max-w-md text-center">
        <div class="relative">
          <img
            src="https://images.unsplash.com/photo-1553279768-865429fa0078?w=600&h=600&fit=crop"
            alt="Mangga segar Indramayu"
            class="w-80 h-80 object-cover rounded-3xl shadow-2xl shadow-primary-900/10 mx-auto"
            width={320}
            height={320}
          />
          <div class="absolute -bottom-4 -right-4 bg-white rounded-2xl shadow-xl p-4 flex items-center gap-3 border border-neutral-100">
            <div class="w-10 h-10 bg-gradient-to-br from-primary-400 to-primary-600 rounded-xl flex items-center justify-center shadow-lg shadow-primary-500/30">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-neutral-900 text-sm">100% Segar</p>
              <p class="text-xs text-neutral-500">Langsung dari kebun</p>
            </div>
          </div>
        </div>
        <h2 class="mt-8 font-display text-2xl font-bold text-neutral-900">
          Mangga Segar dari Kebun
        </h2>
        <p class="mt-2 text-neutral-500">
          Beli langsung dari petani Indramayu. Harga transparan, kualitas terjamin.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
