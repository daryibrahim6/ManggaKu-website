---
import BaseLayout from '../../components/layout/BaseLayout.astro'
import { ForgotPasswordForm } from '../../components/auth/ForgotPasswordForm'
---

<BaseLayout title="Lupa Password">
  <div class="min-h-screen flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2 font-display font-bold text-2xl text-primary-600">
          ManggaKu
        </a>
        <h1 class="mt-4 font-display text-3xl font-bold text-neutral-900">
          Lupa Password
        </h1>
        <p class="mt-2 text-neutral-500">
          Masukkan email kamu untuk reset password
        </p>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-neutral-100 p-6 md:p-8">
        <ForgotPasswordForm client:load />
      </div>

      <p class="mt-6 text-center text-sm text-neutral-500">
        <a href="/auth/masuk" class="font-medium text-primary-600 hover:text-primary-700">
          ← Kembali ke login
        </a>
      </p>
    </div>
  </div>
</BaseLayout>
