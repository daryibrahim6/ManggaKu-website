---
import MarketingLayout from '../components/layout/MarketingLayout.astro'
import { HeroSection } from '../components/marketing/HeroSection'
import { StatsBar } from '../components/marketing/StatsBar'
import { HowItWorks } from '../components/marketing/HowItWorks'
import { FeaturesGrid } from '../components/marketing/FeaturesGrid'
import { TestimoniSection } from '../components/marketing/TestimoniSection'
import { CTASection } from '../components/marketing/CTASection'
---

<MarketingLayout title="Beranda">
  <HeroSection client:only="react" />
  <StatsBar client:visible />
  <HowItWorks client:visible />
  <FeaturesGrid client:visible />
  <TestimoniSection client:visible />
  <CTASection client:visible />
</MarketingLayout>
